# coding-agent-memory-kit environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — your secrets stay local.
#
# Place this file in either:
#   .github/skills/repo-memory/.env  (skill-local, checked first)
#   <repo-root>/.env                 (repo-root, checked second)
#
# Real environment variables always take precedence over .env values.

# ── Required ─────────────────────────────────────────────────────────────────

# Azure Cosmos DB endpoint (NoSQL API with vector search enabled)
# Example: https://your-account.documents.azure.com:443/
COSMOS_DB_ENDPOINT=

# Azure AI Foundry endpoint (for vector embeddings / semantic search)
# Example: https://your-resource.cognitiveservices.azure.com/
AI_FOUNDRY_ENDPOINT=

# ── Optional (have sensible defaults) ────────────────────────────────────────

# Cosmos DB database name (default: agent_memory)
# COSMOS_DB_DATABASE=agent_memory

# Cosmos DB container name (default: memories)
# COSMOS_DB_CONTAINER=memories

# Embedding model name (default: text-embedding-3-large)
# EMBEDDING_MODEL=text-embedding-3-large

# Azure Durable Functions endpoint (for summarization/fact extraction)
# ADF_ENDPOINT=
# ADF_KEY=
